@page
@model AirsoftEquipmentTracker.Pages.Account.RegisterModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create account — Airsoft Tracker</title>
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="auth-body">

<div class="auth-centered">
    <div class="auth-card">
        <div class="brand" style="margin-bottom: 4px;">
            <span class="brand-square"></span>
            Airsoft Tracker
        </div>

        <p class="form-eyebrow">Get started</p>
        <h2 class="form-heading">Create your account</h2>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="validation-summary">
                <ul>
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }

        <form method="post">
            <div class="field-group">
                <label class="field-label" for="displayName">Display name</label>
                <input class="auth-input" type="text" id="displayName" asp-for="Input.DisplayName"
                       placeholder="Xander Meyen" autocomplete="name" />
                <span asp-validation-for="Input.DisplayName" class="field-error"></span>
            </div>

            <div class="field-group">
                <label class="field-label" for="email">Email</label>
                <input class="auth-input" type="email" id="email" asp-for="Input.Email"
                       placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="field-error"></span>
            </div>

            <div class="field-group">
                <label class="field-label" for="password">Password</label>
                <div class="input-wrap">
                    <input class="auth-input" type="password" id="password" asp-for="Input.Password"
                           placeholder="At least 8 characters" autocomplete="new-password"
                           oninput="updateStrength(this.value)" />
                    <button type="button" class="show-toggle" onclick="togglePassword('password', this)">Show</button>
                </div>
                <div class="strength-bar">
                    <div class="strength-fill" id="strengthFill"></div>
                </div>
                <span asp-validation-for="Input.Password" class="field-error"></span>
            </div>

            <button type="submit" class="btn-olive" style="margin-top: 12px;">Create account</button>

            <p class="terms-text">
                By continuing you agree to the <a href="#">terms</a> &amp; <a href="#">privacy policy</a>.
            </p>
        </form>

        <p class="auth-footer">
            Already have an account? <a href="/Account/Login">Sign in</a>
        </p>
    </div>
</div>

<script>
    function togglePassword(inputId, btn) {
        const input = document.getElementById(inputId);
        if (input.type === 'password') {
            input.type = 'text';
            btn.textContent = 'Hide';
        } else {
            input.type = 'password';
            btn.textContent = 'Show';
        }
    }

    function updateStrength(value) {
        const fill = document.getElementById('strengthFill');
        let score = 0;
        if (value.length >= 8)  score++;
        if (value.length >= 12) score++;
        if (/[A-Z]/.test(value)) score++;
        if (/[0-9]/.test(value)) score++;
        if (/[^A-Za-z0-9]/.test(value)) score++;

        const widths  = ['0%', '20%', '40%', '65%', '85%', '100%'];
        const colours = ['transparent', '#e74c3c', '#e67e22', '#f1c40f', '#57642a', '#2ecc71'];

        fill.style.width      = widths[score]  ?? '100%';
        fill.style.background = colours[score] ?? '#2ecc71';
    }
</script>
</body>
</html>
