@page "/"
@rendermode InteractiveServer

@using System.Linq
@using System.Globalization
@using AirsoftEquipmentTracker.Models
@inject AirsoftEquipmentTracker.Services.EquipmentService EquipmentService
@inject NavigationManager Navigation

<PageTitle>Dashboard</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Dashboard</h1>
        <p class="text-muted mb-0">Overview of your airsoft equipment and recent additions.</p>
    </div>

    <button class="btn btn-dark" @onclick="GoToEquipment">
        View Equipment
    </button>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <p class="eyebrow mb-2">Owned Items</p>
                <p class="stat-value mb-0">@ownedCount</p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <p class="eyebrow mb-2">Total Value (Owned)</p>
                <p class="stat-value accent mb-0">€ @totalValue.ToString("0.00")</p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <p class="eyebrow mb-2">Wishlist Value</p>
                <p class="stat-value mb-0">€ @wishlistValue.ToString("0.00")</p>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body">
                <p class="eyebrow mb-2">Categories Used</p>
                <p class="stat-value mb-0">@categoryCount</p>
            </div>
        </div>
    </div>
</div>

<div class="mb-5">
    <h3 class="mb-3">Category Breakdown</h3>

    <div class="row g-4">
        @foreach (var category in categoryBreakdown)
        {
            <div class="col-md-6 col-xl-3">
                <div class="card h-100">
                    <div class="card-body">
                        <p class="eyebrow mb-2">@category.Name</p>
                        <p class="stat-value mb-0">@category.Count</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div>
    <h3 class="mb-3">Recent Items</h3>

    @if (recentEquipment.Any())
    {
        <div class="row g-4">
            @foreach (var item in recentEquipment)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="card h-100">
                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">@item.Name</h5>
                                <span class="badge text-bg-dark">@item.Category?.Name</span>
                            </div>

                            <p class="card-text mb-1">
                                <strong>Brand:</strong> @item.Brand?.Name
                            </p>

                            <p class="card-text mb-1">
                                <strong>Price:</strong> € @item.Price.ToString("0.00")
                            </p>

                            <p class="card-text mb-2">
                                <strong>Purchased:</strong>
                                @item.PurchaseDate.ToString("d", CultureInfo.GetCultureInfo("nl-BE"))
                            </p>

                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                            {
                                <p class="card-text text-muted mb-0">@item.Notes</p>
                            }

                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No recent equipment found.
        </div>
    }
</div>

@code {

    private List<EquipmentItem> equipment = new();

    private int ownedCount;

    private decimal totalValue;

    private decimal wishlistValue;

    private int categoryCount;

    private List<EquipmentItem> recentEquipment = new();

    private List<CategoryStat> categoryBreakdown = new();

    protected override async Task OnInitializedAsync()
    {
        equipment = await EquipmentService.GetEquipmentAsync();

        // Totalen tellen alleen Owned items mee; de wishlist krijgt een eigen kaart
        var owned = equipment.Where(x => x.Status == EquipmentStatus.Owned).ToList();

        ownedCount = owned.Count;

        totalValue = owned.Sum(x => x.Price);

        wishlistValue = equipment
            .Where(x => x.Status == EquipmentStatus.Wishlist)
            .Sum(x => x.Price);

        categoryCount = owned
            .Select(x => x.Category?.Name)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct()
            .Count();

        recentEquipment = owned
            .OrderByDescending(x => x.PurchaseDate)
            .Take(3)
            .ToList();

        categoryBreakdown = owned
            .Where(x => !string.IsNullOrWhiteSpace(x.Category?.Name))
            .GroupBy(x => x.Category!.Name)
            .Select(group => new CategoryStat
            {
                Name = group.Key,
                Count = group.Count()
            })
            .OrderBy(x => x.Name)
            .ToList();
    }

    private void GoToEquipment()
    {
        Navigation.NavigateTo("/equipment");
    }

    private class CategoryStat
    {
        public string Name { get; set; } = string.Empty;
        public int Count { get; set; }
    }

}
