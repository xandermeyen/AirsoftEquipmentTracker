@page "/equipment"
@rendermode InteractiveServer

@using Airsoft_equipment_tracker.Models
@inject Airsoft_equipment_tracker.Services.EquipmentService EquipmentService
@inject Airsoft_equipment_tracker.Services.ImageService Images

<h1 class="mb-2">Equipment</h1>
<p class="text-muted mb-4">Overview of your airsoft replicas, gear, and other tracked items.</p>

<a class="btn btn-dark mb-4" href="/equipment/add">
    Add New Equipment
</a>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <label for="search" class="eyebrow d-block mb-2">Search</label>
        <input id="search" type="text" class="form-control" placeholder="Search by name or brand..."
               @bind="searchText" @bind:event="oninput" />
    </div>

    <div class="col-md-3">
        <label for="category" class="eyebrow d-block mb-2">Filter by category</label>
        <select id="category" class="form-select" @bind="selectedCategory">
            <option value="All">All</option>
            @foreach (var category in Categories)
            {
                <option value="@category">@category</option>
            }
        </select>
    </div>

    <div class="col-md-3">
        <label for="status" class="eyebrow d-block mb-2">Filter by status</label>
        <select id="status" class="form-select" @bind="selectedStatus">
            <option value="All">All</option>
            <option value="Owned">Owned</option>
            <option value="Sold">Sold</option>
            <option value="Wishlist">Wishlist</option>
        </select>
    </div>

    <div class="col-md-3">
        <label for="sort" class="eyebrow d-block mb-2">Sort by</label>
        <select id="sort" class="form-select" @bind="selectedSort">
            <option value="newest">Newest first</option>
            <option value="name">Name (A-Z)</option>
            <option value="price">Price (high to low)</option>
            <option value="date">Purchase date (oldest first)</option>
        </select>
    </div>
</div>

@if (isLoading)
{
    <!-- Laadindicator terwijl de data uit de database komt -->
    <div class="d-flex align-items-center gap-2 text-muted py-5 justify-content-center">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Loading equipment...</span>
    </div>
}
else if (FilteredEquipment.Any())
{
    <div class="row g-4">
        @foreach (var item in FilteredEquipment)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                    {
                        <img src="@item.ImagePath" class="card-img-top" alt="Photo of @item.Name"
                             style="height: 180px; object-fit: cover;" />
                    }
                    else
                    {
                        <!-- Placeholder als er nog geen foto is -->
                        <div class="card-img-top d-flex align-items-center justify-content-center bg-light text-muted"
                             style="height: 180px;">
                            <svg width="48" height="48" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                                <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
                                <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/>
                            </svg>
                        </div>
                    }
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">@item.Name</h5>
                            <span class="badge @StatusBadgeClass(item.Status)">@item.Status</span>
                        </div>
                        <p class="card-text mb-1"><strong>Brand:</strong> @item.Brand?.Name</p>
                        <p class="card-text mb-1"><strong>Category:</strong> @item.Category?.Name</p>
                        <p class="card-text mb-1"><strong>Price:</strong> € @item.Price.ToString("0.00")</p>
                        <p class="card-text mb-1"><strong>Purchase Date:</strong> @item.PurchaseDate.ToShortDateString()</p>

                        @if (!string.IsNullOrWhiteSpace(item.Notes))
                        {
                            <p class="card-text mt-3">
                                <strong>Notes:</strong> @item.Notes
                            </p>
                        }

                        <!-- Edit + delete acties per item -->
                        <div class="d-flex gap-2 mt-3">
                            <a class="btn btn-sm btn-outline-dark" href="@($"/equipment/edit/{item.Id}")">
                                Edit
                            </a>

                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => AskDelete(item)">
                                Delete
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (!equipment.Any())
{
    <!-- Lege staat: er is nog helemaal geen equipment -->
    <div class="text-center py-5">
        <h5 class="mb-2">No equipment yet</h5>
        <p class="text-muted mb-3">Start tracking your loadout by adding your first item.</p>
        <a class="btn btn-dark" href="/equipment/add">Add New Equipment</a>
    </div>
}
else
{
    <!-- Lege staat: wel equipment, maar niets matcht de zoekterm/filter -->
    <div class="text-center py-5">
        <h5 class="mb-2">No matching equipment</h5>
        <p class="text-muted mb-3">No items match your current search or filter.</p>
        <button type="button" class="btn btn-outline-dark" @onclick="ClearFilters">Clear filters</button>
    </div>
}

<!-- Bevestigingsmodal voor delete. Wordt alleen getoond als itemToDelete gezet is. -->
@if (itemToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete equipment</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">
                        Are you sure you want to delete <strong>@itemToDelete.Name</strong>?
                        This action cannot be undone.
                    </p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDelete">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDelete">
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Donkere achtergrond achter de modal -->
    <div class="modal-backdrop fade show"></div>
}

    @code {
        private List<EquipmentItem> equipment = new();
        private string selectedCategory = "All";
        private string selectedStatus = "All";
        private string searchText = string.Empty;
        private string selectedSort = "newest";
        private bool isLoading = true;

        // Item waarvoor de delete-bevestiging open staat. Null = geen modal.
        private EquipmentItem? itemToDelete;

        // Filtert op categorie en zoekterm (naam of merk), en sorteert daarna.
        // De zoekterm is hoofdletterongevoelig.
        private IEnumerable<EquipmentItem> FilteredEquipment
        {
            get
            {
                var result = selectedCategory == "All"
                    ? equipment
                    : equipment.Where(item => item.Category?.Name == selectedCategory);

                if (selectedStatus != "All")
                    result = result.Where(item => item.Status.ToString() == selectedStatus);

                if (!string.IsNullOrWhiteSpace(searchText))
                {
                    var term = searchText.Trim();
                    result = result.Where(item =>
                        item.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                        (item.Brand?.Name.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false));
                }

                return selectedSort switch
                {
                    "name" => result.OrderBy(item => item.Name),
                    "price" => result.OrderByDescending(item => item.Price),
                    "date" => result.OrderBy(item => item.PurchaseDate),
                    _ => result.OrderByDescending(item => item.PurchaseDate) // newest first (default)
                };
            }
        }

        // Returns all unique category names from the equipment list,
        // excluding empty values and sorting them alphabetically.
        private IEnumerable<string> Categories => equipment
            .Select(item => item.Category?.Name)
            .Where(name => !string.IsNullOrWhiteSpace(name))
            .Distinct()
            .OrderBy(name => name)!;

    protected override async Task OnInitializedAsync()
    {
        equipment = await EquipmentService.GetEquipmentAsync();
        isLoading = false;
    }

    // Reset zoekterm en filters zodat de volledige lijst weer zichtbaar is
    private void ClearFilters()
    {
        searchText = string.Empty;
        selectedCategory = "All";
        selectedStatus = "All";
    }

    // Bootstrap badge-kleur per status
    private static string StatusBadgeClass(EquipmentStatus status) => status switch
    {
        EquipmentStatus.Sold => "text-bg-secondary",
        EquipmentStatus.Wishlist => "text-bg-warning",
        _ => "text-bg-dark"
    };

    // Opent de bevestigingsmodal voor het gekozen item
    private void AskDelete(EquipmentItem item)
    {
        itemToDelete = item;
    }

    // Sluit de modal zonder te verwijderen
    private void CancelDelete()
    {
        itemToDelete = null;
    }

    // Verwijdert het item (en zijn foto) en ververst de lijst
    private async Task ConfirmDelete()
    {
        if (itemToDelete is null)
            return;

        var imagePath = itemToDelete.ImagePath;

        await EquipmentService.DeleteEquipmentAsync(itemToDelete.Id);

        // Foto pas opruimen nadat het item zelf weg is
        Images.DeleteImage(imagePath);

        itemToDelete = null;
        equipment = await EquipmentService.GetEquipmentAsync();
    }
}
