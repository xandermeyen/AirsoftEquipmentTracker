@page
@model AirsoftEquipmentTracker.Pages.Account.ForgotPasswordModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset password — Airsoft Tracker</title>
    <link rel="stylesheet" href="~/css/auth.css" />
</head>
<body class="auth-body">

<div class="auth-centered">
    <div class="auth-card">
        <div class="brand" style="margin-bottom: 4px;">
            <span class="brand-square"></span>
            Airsoft Tracker
        </div>

        @if (Model.EmailSent)
        {
            <p class="form-eyebrow" style="margin-top: 24px;">Check your email</p>
            <h2 class="form-heading">Link sent</h2>
            <p style="font-size:14px; color:#555; line-height:1.6; margin-bottom:24px;">
                If an account exists for <strong>@Model.SentTo</strong>, you'll receive
                a password reset link shortly. Check your spam folder if it doesn't show up.
            </p>
            <a class="back-link" href="/Account/Login">← Back to sign in</a>
        }
        else
        {
            <p class="form-eyebrow" style="margin-top: 24px;">Reset access</p>
            <h2 class="form-heading">Forgot your password?</h2>
            <p style="font-size:14px; color:#555; line-height:1.6; margin-bottom:24px;">
                Enter your email and we'll send a link to reset it.
                The link expires in 30 minutes.
            </p>

            <form method="post">
                <div class="field-group">
                    <label class="field-label" for="email">Email</label>
                    <input class="auth-input" type="email" id="email" asp-for="Input.Email"
                           placeholder="you@example.com" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="field-error"></span>
                </div>

                <button type="submit" class="btn-olive">Send reset link</button>
            </form>

            <a class="back-link" href="/Account/Login">← Back to sign in</a>
        }
    </div>
</div>

</body>
</html>
