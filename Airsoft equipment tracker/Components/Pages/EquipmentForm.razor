@using Airsoft_equipment_tracker.Models
@using Airsoft_equipment_tracker.Services
@inject Airsoft_equipment_tracker.Services.EquipmentService EquipmentService
@inject Airsoft_equipment_tracker.Services.ImageService Images

<EditForm Model="Model" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />
    <div class="row g-4">

        <!-- Name -->
        <div class="col-md-6">
            <label class="form-label">Name</label>
            <InputText class="form-control" @bind-Value="Model.Name" />
            <ValidationMessage For="() => Model.Name" class="text-danger small" />
        </div>

        <!-- Price -->
        <div class="col-md-6">
            <label class="form-label">Price</label>
            <InputNumber class="form-control" @bind-Value="Model.Price" />
            <ValidationMessage For="() => Model.Price" class="text-danger small" />
        </div>

        <!-- Brand: kies bestaande of voeg een nieuwe toe -->
        <div class="col-md-6">
            <label class="form-label">Brand</label>

            @if (!addingNewBrand)
            {
                <select class="form-select" @bind="selectedBrandId">
                    <option value="0">Select brand</option>
                    @foreach (var brand in Brands)
                    {
                        <option value="@brand.Id">@brand.Name</option>
                    }
                </select>
                <button type="button" class="btn btn-link btn-sm px-0 mt-1" @onclick="StartNewBrand">
                    + New brand
                </button>
            }
            else
            {
                <InputText class="form-control" @bind-Value="newBrandName" placeholder="New brand name" />
                <button type="button" class="btn btn-link btn-sm px-0 mt-1" @onclick="CancelNewBrand">
                    Choose existing brand
                </button>
            }
        </div>

        <!-- Category: kies bestaande of voeg een nieuwe toe -->
        <div class="col-md-6">
            <label class="form-label">Category</label>

            @if (!addingNewCategory)
            {
                <select class="form-select" @bind="selectedCategoryId">
                    <option value="0">Select category</option>
                    @foreach (var category in Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
                <button type="button" class="btn btn-link btn-sm px-0 mt-1" @onclick="StartNewCategory">
                    + New category
                </button>
            }
            else
            {
                <InputText class="form-control" @bind-Value="newCategoryName" placeholder="New category name" />
                <button type="button" class="btn btn-link btn-sm px-0 mt-1" @onclick="CancelNewCategory">
                    Choose existing category
                </button>
            }
        </div>

        <!-- Purchase Date -->
        <div class="col-md-6">
            <label class="form-label">Purchase Date</label>
            <InputDate class="form-control" @bind-Value="Model.PurchaseDate" />
            <ValidationMessage For="() => Model.PurchaseDate" class="text-danger small" />
        </div>

        <!-- Status -->
        <div class="col-md-6">
            <label class="form-label">Status</label>
            <InputSelect class="form-select" @bind-Value="Model.Status">
                <option value="@EquipmentStatus.Owned">Owned</option>
                <option value="@EquipmentStatus.Sold">Sold</option>
                <option value="@EquipmentStatus.Wishlist">Wishlist</option>
            </InputSelect>
        </div>

        <!-- Photo -->
        <div class="col-md-6">
            <label class="form-label">Photo</label>

            @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
            {
                <div class="mb-2">
                    <img src="@Model.ImagePath" alt="Current photo of @Model.Name"
                         class="rounded border" style="max-height: 120px;" />
                </div>
            }

            <InputFile class="form-control" OnChange="OnImageSelected" accept=".jpg,.jpeg,.png,.webp" />
            <div class="form-text">JPG, PNG or WebP, max 5 MB.</div>
        </div>

        <!-- Notes -->
        <div class="col-12">
            <label class="form-label">Notes</label>
            <InputTextArea class="form-control" rows="4" @bind-Value="Model.Notes" />
            <ValidationMessage For="() => Model.Notes" class="text-danger small" />
        </div>

        <!-- Foutmelding -->
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="col-12">
                <div class="alert alert-warning mb-0">@error</div>
            </div>
        }

        <!-- Buttons -->
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-dark">@SubmitLabel</button>
            <button type="button" class="btn btn-outline-secondary" @onclick="OnCancel">Cancel</button>
        </div>

    </div>
</EditForm>

@code {

    [Parameter] public EquipmentItem Model { get; set; } = default!;
    [Parameter] public List<Brand> Brands { get; set; } = new();
    [Parameter] public List<Category> Categories { get; set; } = new();
    [Parameter] public string SubmitLabel { get; set; } = "Save";
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnValidSubmit { get; set; }

    private int selectedBrandId;
    private int selectedCategoryId;
    private bool addingNewBrand;
    private bool addingNewCategory;
    private string newBrandName = string.Empty;
    private string newCategoryName = string.Empty;
    private string? error;

    // Gekozen foto; wordt pas opgeslagen bij submit
    private IBrowserFile? selectedImage;

    protected override void OnParametersSet()
    {
        // Prefill dropdowns voor de edit-pagina (BrandId/CategoryId zijn dan al gezet)
        if (selectedBrandId == 0 && Model.BrandId != 0)
            selectedBrandId = Model.BrandId;
        if (selectedCategoryId == 0 && Model.CategoryId != 0)
            selectedCategoryId = Model.CategoryId;
    }

    private async Task HandleSubmit()
    {
        error = null;

        if (addingNewBrand)
        {
            if (string.IsNullOrWhiteSpace(newBrandName))
            {
                error = "Enter a name for the new brand, or choose an existing one.";
                return;
            }
            try
            {
                var brand = await EquipmentService.AddBrandAsync(newBrandName);
                selectedBrandId = brand.Id;
                if (!Brands.Any(b => b.Id == brand.Id))
                    Brands.Add(brand);
                addingNewBrand = false;
                newBrandName = string.Empty;
            }
            catch (Exception)
            {
                error = "Could not save the new brand. Please try again.";
                return;
            }
        }

        if (addingNewCategory)
        {
            if (string.IsNullOrWhiteSpace(newCategoryName))
            {
                error = "Enter a name for the new category, or choose an existing one.";
                return;
            }
            try
            {
                var category = await EquipmentService.AddCategoryAsync(newCategoryName);
                selectedCategoryId = category.Id;
                if (!Categories.Any(c => c.Id == category.Id))
                    Categories.Add(category);
                addingNewCategory = false;
                newCategoryName = string.Empty;
            }
            catch (Exception)
            {
                error = "Could not save the new category. Please try again.";
                return;
            }
        }

        if (selectedBrandId == 0 || selectedCategoryId == 0)
        {
            error = "Please select or add both a brand and a category.";
            return;
        }

        Model.BrandId = selectedBrandId;
        Model.CategoryId = selectedCategoryId;

        // Foto opslaan (en de oude vervangen) als er een nieuwe gekozen is
        if (selectedImage is not null)
        {
            var imageError = ImageService.Validate(selectedImage);
            if (imageError is not null)
            {
                error = imageError;
                return;
            }

            try
            {
                var oldImage = Model.ImagePath;
                Model.ImagePath = await Images.SaveImageAsync(selectedImage);
                Images.DeleteImage(oldImage);
            }
            catch (Exception)
            {
                error = "Could not save the image. Please try again.";
                return;
            }
        }

        try
        {
            await OnValidSubmit.InvokeAsync();
        }
        catch (Exception)
        {
            error = "Something went wrong while saving. Please try again.";
        }
    }

    private void OnImageSelected(InputFileChangeEventArgs e)
    {
        selectedImage = e.File;
        error = null;
    }

    private void StartNewBrand() => addingNewBrand = true;
    private void CancelNewBrand() { addingNewBrand = false; newBrandName = string.Empty; }
    private void StartNewCategory() => addingNewCategory = true;
    private void CancelNewCategory() { addingNewCategory = false; newCategoryName = string.Empty; }
}
