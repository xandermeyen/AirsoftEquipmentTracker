# ==========================================
#  .NET / Blazor .gitignore
# ==========================================

# Build results
bin/
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Bb]in/
[Oo]bj/

# Visual Studio
.vs/
*.user
*.suo
*.cache
*.userprefs
*.userosscache
*.sln.docstates

# Rider / JetBrains
.idea/
*.sln.iml

# VS Code (optioneel — verwijder als je je settings wél wil delen)
.vscode/

# ==========================================
#  Secrets & configuratie — NOOIT committen
# ==========================================

# Environment-specifieke settings (bevatten vaak wachtwoorden/keys)
appsettings.*.json
# Let op: appsettings.json zelf wordt WEL gecommit (zonder echte secrets erin)

# User secrets worden buiten de projectmap opgeslagen, maar voor de zekerheid
secrets.json

# Environment files
.env
.env.local
*.env.local

# ==========================================
#  NuGet
# ==========================================
*.nupkg
*.snupkg
.nuget/
**/packages/*
!**/packages/build/

# ==========================================
#  Publish output
# ==========================================
publish/
**/publish/
*.publishsettings
PublishProfiles/

# ==========================================
#  User-specific overrides
# ==========================================
Properties/launchSettings.json

# ==========================================
#  Test results
# ==========================================
TestResults/
[Tt]est[Rr]esults/
*.trx
*.coverage
*.coverML

# ==========================================
#  OS files
# ==========================================
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ==========================================
#  Uploads (door gebruikers toegevoegde foto's)
# ==========================================
Airsoft equipment tracker/wwwroot/uploads/

# ==========================================
#  Claude Code
# ==========================================
.claude/
