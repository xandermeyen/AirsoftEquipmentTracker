@page "/equipment/add"
@rendermode InteractiveServer

@using Airsoft_equipment_tracker.Models
@inject Airsoft_equipment_tracker.Services.MockEquipmentService EquipmentService
@inject NavigationManager Navigation

<h1 class="mb-2">Add Equipment</h1>
<p class="text-muted mb-4">Add a new item to your airsoft equipment tracker.</p>

<div class="card border-0 shadow-sm">
    <div class="card-body">

        <EditForm Model="newItem" OnValidSubmit="HandleSubmit">
            <div class="row g-4">

                <!-- Name -->
                <div class="col-md-6">
                    <label class="form-label">Name</label>
                    <InputText class="form-control" @bind-Value="newItem.Name" />
                </div>

                <!-- Price -->
                <div class="col-md-6">
                    <label class="form-label">Price</label>
                    <InputNumber class="form-control" @bind-Value="newItem.Price" />
                </div>

                <!-- Brand dropdown -->
                <div class="col-md-6">
                    <label class="form-label">Brand</label>
                    <select class="form-select" @bind="selectedBrand">
                        <option value="">Select brand</option>

                        @foreach (var brand in Brands)
                        {
                            <option value="@brand">@brand</option>
                        }
                    </select>
                </div>

                <!-- Category dropdown -->
                <div class="col-md-6">
                    <label class="form-label">Category</label>
                    <select class="form-select" @bind="selectedCategory">
                        <option value="">Select category</option>

                        @foreach (var category in Categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                </div>

                <!-- Date -->
                <div class="col-md-6">
                    <label class="form-label">Purchase Date</label>
                    <InputDate class="form-control" @bind-Value="newItem.PurchaseDate" />
                </div>

                <!-- Notes -->
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <InputTextArea class="form-control" rows="4" @bind-Value="newItem.Notes" />
                </div>

                <!-- Buttons -->
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-dark">Save Equipment</button>

                    <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">
                        Cancel
                    </button>
                </div>

            </div>
        </EditForm>

    </div>
</div>

@code {

    private EquipmentItem newItem = new()
    {
        PurchaseDate = DateTime.Today
    };

    private string selectedCategory = "";
    private string selectedBrand = "";

    // Get existing equipment (used to extract categories + brands)
    private List<EquipmentItem> equipment = new();

    // Unique category list
    private IEnumerable<string> Categories => equipment
        .Select(x => x.Category?.Name)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)!;

    // Unique brand list
    private IEnumerable<string> Brands => equipment
        .Select(x => x.Brand?.Name)
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x)!;

    protected override void OnInitialized()
    {
        equipment = EquipmentService.GetEquipment();
    }

    private void HandleSubmit()
    {
        // Simple validation (avoid empty dropdowns)
        if (string.IsNullOrWhiteSpace(selectedCategory) || string.IsNullOrWhiteSpace(selectedBrand))
            return;

        // Convert selected values to objects
        newItem.Category = new Category { Name = selectedCategory };
        newItem.Brand = new Brand { Name = selectedBrand };

        // Save via service
        EquipmentService.AddEquipment(newItem);

        // Navigate back to equipment page
        Navigation.NavigateTo("/equipment");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/equipment");
    }
}