@page "/equipment/edit/{Id:int}"
@rendermode InteractiveServer

@using Airsoft_equipment_tracker.Models
@inject Airsoft_equipment_tracker.Services.EquipmentService EquipmentService
@inject NavigationManager Navigation

<h1 class="mb-2">Edit Equipment</h1>
<p class="text-muted mb-4">Update the details of an existing item in your tracker.</p>

@if (notFound)
{
    <div class="alert alert-warning">
        Equipment item not found.
    </div>

    <a class="btn btn-outline-secondary" href="/equipment">Back to overview</a>
}
else if (editItem is null)
{
    <p class="text-muted">Loading...</p>
}
else
{
    <div class="card">
        <div class="card-body">

            <EditForm Model="editItem" OnValidSubmit="HandleSubmit">
                <div class="row g-4">

                    <!-- Name -->
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="editItem.Name" />
                    </div>

                    <!-- Price -->
                    <div class="col-md-6">
                        <label class="form-label">Price</label>
                        <InputNumber class="form-control" @bind-Value="editItem.Price" />
                    </div>

                    <!-- Brand: kies bestaande of voeg een nieuwe toe -->
                    <div class="col-md-6">
                        <label class="form-label">Brand</label>

                        @if (!addingNewBrand)
                        {
                            <select class="form-select" @bind="selectedBrandId">
                                <option value="0">Select brand</option>

                                @foreach (var brand in brands)
                                {
                                    <option value="@brand.Id">@brand.Name</option>
                                }
                            </select>
                            <button type="button" class="btn btn-link btn-sm px-0 mt-1" @onclick="StartNewBrand">
                                + New brand
                            </button>
                        }
                        else
                        {
                            <InputText class="form-control" @bind-Value="newBrandName" placeholder="New brand name" />
                            <button type="button" class="btn btn-link btn-sm px-0 mt-1" @onclick="CancelNewBrand">
                                Choose existing brand
                            </button>
                        }
                    </div>

                    <!-- Category: kies bestaande of voeg een nieuwe toe -->
                    <div class="col-md-6">
                        <label class="form-label">Category</label>

                        @if (!addingNewCategory)
                        {
                            <select class="form-select" @bind="selectedCategoryId">
                                <option value="0">Select category</option>

                                @foreach (var category in categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <button type="button" class="btn btn-link btn-sm px-0 mt-1" @onclick="StartNewCategory">
                                + New category
                            </button>
                        }
                        else
                        {
                            <InputText class="form-control" @bind-Value="newCategoryName" placeholder="New category name" />
                            <button type="button" class="btn btn-link btn-sm px-0 mt-1" @onclick="CancelNewCategory">
                                Choose existing category
                            </button>
                        }
                    </div>

                    <!-- Date -->
                    <div class="col-md-6">
                        <label class="form-label">Purchase Date</label>
                        <InputDate class="form-control" @bind-Value="editItem.PurchaseDate" />
                    </div>

                    <!-- Notes -->
                    <div class="col-12">
                        <label class="form-label">Notes</label>
                        <InputTextArea class="form-control" rows="4" @bind-Value="editItem.Notes" />
                    </div>

                    <!-- Validatiemelding -->
                    @if (!string.IsNullOrEmpty(error))
                    {
                        <div class="col-12">
                            <div class="alert alert-warning mb-0">@error</div>
                        </div>
                    }

                    <!-- Buttons -->
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-dark">Save Changes</button>

                        <button type="button" class="btn btn-outline-secondary" @onclick="GoBack">
                            Cancel
                        </button>
                    </div>

                </div>
            </EditForm>

        </div>
    </div>
}

@code {

    [Parameter]
    public int Id { get; set; }

    private EquipmentItem? editItem;
    private bool notFound;

    private int selectedCategoryId;
    private int selectedBrandId;

    private List<Brand> brands = new();
    private List<Category> categories = new();

    // Staat voor het inline toevoegen van een nieuw merk/categorie
    private bool addingNewBrand;
    private bool addingNewCategory;
    private string newBrandName = string.Empty;
    private string newCategoryName = string.Empty;

    private string? error;

    protected override async Task OnInitializedAsync()
    {
        brands = await EquipmentService.GetBrandsAsync();
        categories = await EquipmentService.GetCategoriesAsync();

        // Haal het bestaande item op via de id uit de route
        editItem = await EquipmentService.GetEquipmentByIdAsync(Id);

        if (editItem is null)
        {
            notFound = true;
            return;
        }

        // Dropdowns vooraf invullen met de huidige waarden
        selectedBrandId = editItem.BrandId;
        selectedCategoryId = editItem.CategoryId;
    }

    private void StartNewBrand() => addingNewBrand = true;

    private void CancelNewBrand()
    {
        addingNewBrand = false;
        newBrandName = string.Empty;
    }

    private void StartNewCategory() => addingNewCategory = true;

    private void CancelNewCategory()
    {
        addingNewCategory = false;
        newCategoryName = string.Empty;
    }

    private async Task HandleSubmit()
    {
        if (editItem is null)
            return;

        error = null;

        // Nieuw merk aanmaken (of bestaande terugkrijgen) en koppelen
        if (addingNewBrand)
        {
            if (string.IsNullOrWhiteSpace(newBrandName))
            {
                error = "Enter a name for the new brand, or choose an existing one.";
                return;
            }

            var brand = await EquipmentService.AddBrandAsync(newBrandName);
            selectedBrandId = brand.Id;
        }

        // Zelfde voor categorie
        if (addingNewCategory)
        {
            if (string.IsNullOrWhiteSpace(newCategoryName))
            {
                error = "Enter a name for the new category, or choose an existing one.";
                return;
            }

            var category = await EquipmentService.AddCategoryAsync(newCategoryName);
            selectedCategoryId = category.Id;
        }

        // Simpele validatie: brand en category moeten gekozen zijn
        if (selectedBrandId == 0 || selectedCategoryId == 0)
        {
            error = "Please select or add both a brand and a category.";
            return;
        }

        // Koppel via de foreign keys naar bestaande brand/category
        editItem.BrandId = selectedBrandId;
        editItem.CategoryId = selectedCategoryId;

        await EquipmentService.UpdateEquipmentAsync(editItem);

        Navigation.NavigateTo("/equipment");
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/equipment");
    }
}
